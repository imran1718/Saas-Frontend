# App
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shipping_saas
DB_USER=postgres
DB_PASSWORD=root

# Redis
REDIS_HOST=localhosts
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=your-very-long-random-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-very-long-random-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Platform Admin Auth (separate secrets from tenant auth)
PLATFORM_JWT_ACCESS_SECRET=your-platform-very-long-random-access-secret-min-32-chars
PLATFORM_JWT_REFRESH_SECRET=your-platform-very-long-random-refresh-secret-min-32-chars
PLATFORM_JWT_ACCESS_EXPIRY=15m
PLATFORM_JWT_REFRESH_EXPIRY=7d
PLATFORM_IMPERSONATION_TOKEN_EXPIRY=30m
PLATFORM_ADMIN_FRONTEND_URL=http://localhost:3001

# Email (SMTP) - for dev use Ethereal (auto-provisioned) or fill in real creds
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@shippingsaas.com

# 2FA Encryption (AES-256-GCM) - must be exactly 32 characters
TOTP_ENCRYPTION_KEY=your-32-character-encryption-key!!

# Security
BCRYPT_SALT_ROUNDS=12

# Sequelize CLI (mirrors DB_ vars above)
SEQUELIZE_DIALECT=postgres

# Courier Provider Credentials Encryption (AES-256-GCM) - must be exactly 32 characters
PROVIDER_CREDENTIALS_ENCRYPTION_KEY=your-32-char-provider-cred-key!!
PROVIDER_HEALTH_CHECK_STALE_MINUTES=10
PROVIDER_DEFAULT_TIMEOUT_MS=8000

# Shipment & Rate Comparison Settings
SHIPMENT_RATE_QUOTE_EXPIRY_MINUTES=15
SHIPMENT_RATE_COMPARISON_TIMEOUT_MS=10000
